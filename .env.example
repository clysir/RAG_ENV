# 数据库配置
DATABASE_URL = "xxxx"

# JWT 配置
JWT_SECRET_KEY=your-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30 

# MinIO 配置
MINIO_ENDPOINT=xxxx
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=your-bucket-name
MINIO_SECURE=False

# Ingest/chunk 设置
INGEST_MAX_CHUNKS=3
INGEST_BATCH_SIZE=1
CHUNK_SIZE=2000
CHUNK_OVERLAP=300

#Embedding
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=your-embedding-service-url

#Vector Store
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIRECTORY=your-chroma-persist-directory

# Chat Model
CHAT_MODEL_PROVIDER=deepseek
CHAT_MODEL_NAME=deepseek-v4-flash
CHAT_MODEL_API_KEY=your-chat-model-api-key
CHAT_MODEL_BASE_URL=https://api.deepseek.com
CHAT_MODEL_TEMPERATURE=0.2
CHAT_MODEL_MAX_TOKENS=2048